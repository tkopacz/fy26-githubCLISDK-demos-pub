{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CopilotApi": {
    "AllowedOrigins": [
      "http://localhost:5078",
      "https://localhost:7299"
    ],
    "ApiKeyHeaderName": "X-API-Key",
    "MaxRequestBodyBytes": 65536,
    "MaxPromptChars": 12000,
    "MaxCodeChars": 50000,
    "RateLimitPermitLimit": 20,
    "RateLimitWindowSeconds": 60
  },
  "AllowedHosts": "*"
}
